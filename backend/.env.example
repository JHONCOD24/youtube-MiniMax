# ====== YouTube Data API v3 ======
# Obtén tu key en: https://console.cloud.google.com/apis/credentials
# 1) Crea un proyecto en Google Cloud
# 2) Habilita "YouTube Data API v3"
# 3) Crea una credencial "API key" y cópiala aquí
YOUTUBE_API_KEY=

# ====== Google Gemini API ======
# Obtén tu key gratis en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ====== Anthropic Claude API ======
# Obtén tu key en: https://console.anthropic.com/
CLAUDE_API_KEY=

# ====== Mistral AI API ======
# Obtén tu key en: https://console.mistral.ai/
MISTRAL_API_KEY=

# ====== Servidor ======
PORT=4000
# CORS_ORIGIN es la URL del frontend (Vite usa 5173 por defecto)
CORS_ORIGIN=http://localhost:5173
